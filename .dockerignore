# Version control
.git
.gitignore

# Node & build artifacts
node_modules/
frontend/node_modules/
frontend/.vite/
build/
dist/

# Include CI artifacts when present
!frontend/dist/**

# Environment & configuration
.env
.env.*
!.env.example

# Documentation and metadata
docs/
CHANGELOG.md
README.md

# Editor & system files
.vscode/
.idea/
.DS_Store
*.swp

# Python artifacts
__pycache__/
.venv/
venv/

# Logs & caches
*.log
logs/
*.cache

# Yarn berry data (generated in CI)
.yarn/
frontend/.yarn/
